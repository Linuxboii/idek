# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=991554947...
WA_ACCESS_TOKEN=EAAk...replace_with_long_lived_token
WA_VERIFY_TOKEN=choose_any_random_string

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_MAX_TOKENS=300

# Postgres
DATABASE_URL=postgresql://user:pass@localhost:5432/levelup

# Google Calendar
GCAL_CALENDAR_ID=spacelink2016.digital@gmail.com
# Path inside container/server to service account JSON
GCAL_SERVICE_ACCOUNT_FILE=/app/secrets/gcal-sa.json
# Used for domain-wide delegation only if needed
GCAL_DELEGATED_USER=

# App
LOG_LEVEL=INFO
TIMEZONE_OFFSET=+05:30

# Bearer token for /admin UI + /api/send-template
ADMIN_TOKEN=change-me-to-long-random-string

# CRM Auth
JWT_SECRET=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
BUSINESS_NAME=Your Business Name
